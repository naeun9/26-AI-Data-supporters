# 공공데이터포털(KISED) 일반 인증키 (Decoding 키, 평문)
KISED_SERVICE_KEY=여기에_인증키_입력

# AI 챗봇용 Claude API 키 (https://platform.claude.com 에서 발급)
# 비워두면 챗봇이 키워드 매칭 방식으로만 동작합니다.
ANTHROPIC_API_KEY=

# JWT 서명용 비밀 문자열 (아무 무작위 긴 문자열이면 됨)
JWT_SECRET=change-me-to-a-random-string

# 구글 로그인용 OAuth 클라이언트 ID
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 클라이언트 ID(웹)
# 승인된 자바스크립트 원본에 http://localhost:5173 과 배포 도메인을 등록할 것.
# 비워두면 구글 로그인 버튼이 "설정 필요" 안내를 띄웁니다.
GOOGLE_CLIENT_ID=
